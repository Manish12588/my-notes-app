# SSH Keys — never commit private keys
*.pem
*.key
terraform/terra-automate-key.pem

# ── Terraform ───────────────────────────
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
crash.log
crash.*.log

# Ansible
ansible/inventory.ini

notes-error.txt


--------------- git command ------

git ls-files | Select-String "inventory"
git rm --cached ansible/inventory.ini
git add .gitignore
git commit -m "fix: add inventory.ini to gitignore, untrack it"
git push origin main
